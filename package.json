{
  "name": "@scat1995/archiver",
  "version": "2.0.3",
  "description": "Archive dist folder",
  "type": "module",
  "author": "JY-Mar",
  "license": "ISC",
  "homepage": "https://github.com/JY-Mar/scat-dist-archiver#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/JY-Mar/scat-dist-archiver.git"
  },
  "keywords": [
    "compressor",
    "dist-archiver",
    "scientificat1995"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "import": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsup && npm link",
    "reinstall": "npm install",
    "publish-npmjs": "npm publish --access public"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "compressing": "^1.5.1"
  },
  "peerDependencies": {
    "rollup": ">=2.0.0",
    "vite": ">=2.0.0",
    "webpack": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "unplugin": "^3.0.0"
  }
}

{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext"],
    
    "moduleResolution": "Bundler",
    "strict": false,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": false,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    
    "sourceMap": false,

    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

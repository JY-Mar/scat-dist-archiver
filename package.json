{
  "name": "@scat1995/archiver",
  "version": "2.1.2",
  "description": "dist folder Archiver",
  "type": "module",
  "author": "JY-Mar",
  "license": "ISC",
  "homepage": "https://github.com/JY-Mar/scat-dist-archiver#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/JY-Mar/scat-dist-archiver.git"
  },
  "bugs": {
    "url": "https://github.com/JY-Mar/scat-dist-archiver/issues"
  },
  "keywords": [
    "archiver",
    "dist-archiver",
    "scientificat1995"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "types": {
      "import": "./dist/index.d.ts",
      "require": "./dist/index.d.cts"
    },
    "require": "./dist/index.cjs",
    "import": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsup && node scripts/rewritecjs.cjs",
    "link-g": "npm link",
    "unlink-g": "npm unlink @scat1995/archiver -g",
    "reinstall": "npm install",
    "publish-npmjs": "npm publish --access public",
    "publish-npmjs.beta": "npm publish --tag beta --access public"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "compressing": "^1.10.5",
    "unplugin": "^3.0.0"
  },
  "peerDependencies": {
    "rollup": ">=2.0.0",
    "vite": ">=2.0.0",
    "webpack": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "rimraf": "^6.0.1",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2"
  }
}

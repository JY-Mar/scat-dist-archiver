{
  "name": "@scat1995/archiver",
  "version": "1.0.7",
  "description": "Archive dist folder",
  "type": "module",
  "author": "JY-Mar",
  "license": "ISC",
  "homepage": "https://github.com/JY-Mar/scat-dist-archiver#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/JY-Mar/scat-dist-archiver.git"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "rollup",
    "rollup-plugin",
    "webpack",
    "webpack-plugin",
    "archiver",
    "compress",
    "scat",
    "scientificat1995"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    "require": "./dist/index.cjs.js",
    "import": "./dist/index.esm.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc -w -p .",
    "build": "rimraf dist && rollup -c rollup.config.ts"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-strip": "^3.0.4",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.3.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.21.1",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "compressing": "^1.5.1"
  }
}
